<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.thoor.aether</string>
        <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/dotnet</string>
        <string>exec</string>
        <string>__AETHER_DLL_PATH__</string>
        <string>serve</string>
    </array>
        <key>WorkingDirectory</key>
    <string>__AETHER_BUILD_DIR__</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>AETHER_HOME</key>
        <string>__AETHER_HOME__</string>
        <key>DOTNET_ENVIRONMENT</key>
        <string>Production</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>__AETHER_HOME__/logs/aether.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>__AETHER_HOME__/logs/aether.stderr.log</string>
</dict>
</plist>
