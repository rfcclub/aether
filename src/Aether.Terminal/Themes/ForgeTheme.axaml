<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Forge Theme Colors -->
    <SolidColorBrush x:Key="ForgeAmber">#ffb000</SolidColorBrush>
    <SolidColorBrush x:Key="ForgeBackground">#050505</SolidColorBrush>
    <SolidColorBrush x:Key="ForgeDim">#554400</SolidColorBrush>
    <SolidColorBrush x:Key="ForgeAccent">#ffcc00</SolidColorBrush>
    <SolidColorBrush x:Key="ForgeUserBubble">#1a3a1a</SolidColorBrush>
    <SolidColorBrush x:Key="ForgeToolBubble">#2a1a00</SolidColorBrush>
    <SolidColorBrush x:Key="ForgeError">#ff4444</SolidColorBrush>

    <!-- Scanline Effect -->
    <VisualBrush x:Key="ScanlineBrush"
                 TileMode="Tile"
                 Stretch="None"
                 SourceRect="0,0,1,2"
                 DestinationRect="0,0,1,2">
        <VisualBrush.Visual>
            <Canvas Width="1" Height="2">
                <Rectangle Width="1" Height="1" Fill="Transparent" />
                <Rectangle Width="1" Height="1" Canvas.Top="1" Fill="Black" Opacity="0.5" />
            </Canvas>
        </VisualBrush.Visual>
    </VisualBrush>
</ResourceDictionary>
