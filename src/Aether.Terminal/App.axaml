<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Aether.Terminal.App">
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
    <Application.Resources>
        <!-- Default Mono theme colors -->
        <SolidColorBrush x:Key="TerminalBackground">#1a1a1a</SolidColorBrush>
        <SolidColorBrush x:Key="TerminalForeground">#e0e0e0</SolidColorBrush>
        <SolidColorBrush x:Key="TerminalDim">#444444</SolidColorBrush>
        <SolidColorBrush x:Key="TerminalAccent">#ffffff</SolidColorBrush>
        <SolidColorBrush x:Key="TerminalUserBubble">#2a2a2a</SolidColorBrush>
        <SolidColorBrush x:Key="TerminalToolBubble">#2a2a1a</SolidColorBrush>
        <SolidColorBrush x:Key="TerminalError">#ff6666</SolidColorBrush>
    </Application.Resources>
</Application>
