<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Aether.Terminal.Views"
             x:Class="Aether.Terminal.Views.SilhouetteView">
    <UserControl.Styles>
        <!-- Base Silhouette Style -->
        <Style Selector="Path.silhouette">
            <Setter Property="Fill" Value="{DynamicResource TerminalAccent}" />
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Effect">
                <BlurEffect Radius="15" />
            </Setter>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.5" />
                </Transitions>
            </Setter>
        </Style>

        <!-- Idle/Breathing Animation -->
        <Style Selector="Path.silhouette.idle">
            <Style.Animations>
                <Animation Duration="0:0:4" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.6" />
                        <Setter Property="ScaleTransform.ScaleX" Value="1.0" />
                        <Setter Property="ScaleTransform.ScaleY" Value="1.0" />
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="Opacity" Value="0.8" />
                        <Setter Property="ScaleTransform.ScaleX" Value="1.02" />
                        <Setter Property="ScaleTransform.ScaleY" Value="1.02" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0.6" />
                        <Setter Property="ScaleTransform.ScaleX" Value="1.0" />
                        <Setter Property="ScaleTransform.ScaleY" Value="1.0" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- Thinking/Flicker Animation -->
        <Style Selector="Path.silhouette.thinking">
            <Style.Animations>
                <Animation Duration="0:0:0.5" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.5" />
                    </KeyFrame>
                    <KeyFrame Cue="25%">
                        <Setter Property="Opacity" Value="0.9" />
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="Opacity" Value="0.6" />
                    </KeyFrame>
                    <KeyFrame Cue="75%">
                        <Setter Property="Opacity" Value="0.8" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0.5" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>

    <Panel>
        <!-- Glow/Halo -->
        <Ellipse Width="120" Height="200" Fill="{DynamicResource TerminalAccent}" Opacity="0.1">
            <Ellipse.Effect>
                <BlurEffect Radius="50" />
            </Ellipse.Effect>
        </Ellipse>

        <!-- Silhouette Path -->
        <Path Name="SilhouettePath"
              Classes="silhouette" 
              Classes.idle="{Binding !IsThinking, RelativeSource={RelativeSource AncestorType=views:SilhouetteView}}"
              Classes.thinking="{Binding IsThinking, RelativeSource={RelativeSource AncestorType=views:SilhouetteView}}"
              Data="M 50,20 C 40,20 35,30 35,40 C 35,50 40,60 50,60 C 60,60 65,50 65,40 C 65,30 60,20 50,20 Z M 50,65 C 40,65 30,75 25,90 C 20,105 20,130 20,150 L 20,280 L 80,280 L 80,150 C 80,130 80,105 75,90 C 70,75 60,65 50,65 Z"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
            <Path.RenderTransform>
                <ScaleTransform />
            </Path.RenderTransform>
        </Path>
    </Panel>
</UserControl>
