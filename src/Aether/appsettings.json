{
  "assistant": {
    "name": "Aether",
    "trigger": "@Aether"
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "bot_token": "${TELEGRAM_BOT_TOKEN}"
    }
  },
  "llm": {
    "provider": "openrouter",
    "model": "anthropic/claude-3-5-sonnet",
    "api_key": "${OPENROUTER_API_KEY}",
    "base_url": "https://openrouter.ai/api/v1",
    "timeout_seconds": 90
  },
  "database": {
    "path": "store/aether.db",
    "schema": "Data/Schema.sql"
  },
  "groups": {
    "path": "groups"
  },
  "sandbox": {
    "type": "bwrap",
    "timeout_ms": 30000,
    "max_memory_mb": 512,
    "network_enabled": false,
    "allowed_paths": [
      "/workspace/group",
      "/workspace/global"
    ]
  },
  "scheduler": {
    "check_interval_ms": 60000
  }
}
